{
  "name": "@0xsofia/dashboard-graphql",
  "description": "Sofia Dashboard GraphQL Client for Intuition",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm codegen",
    "build": "tsup",
    "dev": "concurrently \"pnpm codegen:watch\" \"tsup --watch\"",
    "codegen": "NODE_ENV=production graphql-codegen --config codegen.ts",
    "codegen:watch": "NODE_ENV=development graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@graphql-codegen/typescript-document-nodes": "^4.0.11",
    "@tanstack/react-query": "^5.32.0",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/client-preset": "^4.4.0",
    "@graphql-codegen/introspection": "^4.0.3",
    "@graphql-codegen/plugin-helpers": "^5.0.4",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^4.3.0",
    "@graphql-codegen/typescript-react-query": "^6.1.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "concurrently": "^8.2.2",
    "tsup": "^6.7.0",
    "typescript": "^5.4.5"
  }
}
